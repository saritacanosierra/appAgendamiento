{
  "name": "spa-unas",
  "private": true,
  "description": "Agendar Citas — frontend React + backend Node",
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "migrar:all": "npm run migrar:all --prefix backend",
    "test": "npm run test --prefix backend",
    "test:backend": "npm run test --prefix backend",
    "test:integracion": "npm run test:integracion --prefix backend",
    "test:e2e": "playwright test --config e2e/playwright.config.js",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend",
    "verificar:salud": "npm run verificar:salud --prefix backend",
    "build": "npm run build --prefix frontend",
    "build:imagina": "npm run build:imagina --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "preparar:git": "bash scripts/configurar-git-autor.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}
