# Entorno
NODE_ENV=desarrollo
PUERTO=3001
ZONA_HORARIA=America/Mexico_City

# MySQL (XAMPP)
DB_HOST=127.0.0.1
DB_PUERTO=3306
DB_NOMBRE=spa_unas
DB_USUARIO=root
DB_CONTRASENA=

# Seguridad
CLAVE_SECRETA_SESION=cambiar-esta-clave-en-produccion
# Panel superadmin (/api/plataforma/*). En produccion solo-marca usar false.
# En desarrollo se habilita salvo PLATAFORMA_HABILITADA=false
# PLATAFORMA_HABILITADA=false
# Cuenta unica operador SaaS (npm run semilla:superadmin)
# SUPERADMIN_CORREO=saritacanosierra@gmail.com
# SUPERADMIN_CONTRASENA=cambiar-en-produccion
# SUPERADMIN_NOMBRE=Operador Plataforma
TOKEN_EXPIRACION_HORAS=168
TOKEN_ROTACION_HORAS=24

# Email (opcional — confirmacion de reservas)
SMTP_HOST=
SMTP_PUERTO=587
SMTP_SEGURO=0
SMTP_USUARIO=
SMTP_CONTRASENA=
EMAIL_REMITENTE=Spa Unas <no-reply@tudominio.com>

# WhatsApp Business Cloud API — credenciales **por marca** en Admin → Mi marca
# (Ya no se usa un numero global compartido entre marcas)
WHATSAPP_API_VERSION=v21.0
# Recordatorio automatico 4 h antes del servicio
WHATSAPP_RECORDATORIO_HABILITADO=1
WHATSAPP_RECORDATORIO_HORAS=4
WHATSAPP_RECORDATORIO_VENTANA_MIN=10
WHATSAPP_RECORDATORIO_INTERVALO_MIN=5
# Plantilla aprobada en Meta (recomendado en produccion). Parametros: nombre, marca, servicio, fecha, hora, codigo
# WHATSAPP_PLANTILLA_RECORDATORIO=recordatorio_cita
# WHATSAPP_PLANTILLA_IDIOMA=es_MX

# Optimizacion de imagenes subidas
IMAGEN_ANCHO_MAXIMO=1920
IMAGEN_CALIDAD_WEBP=80

# CORS (separado por coma)
CORS_ORIGENES=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_LOGIN=10
RATE_LIMIT_RESERVAS=20

# Auditoria (logs en backend/logs/)
AUDITORIA_HABILITADA=1

# Google Calendar OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integraciones/google/callback
