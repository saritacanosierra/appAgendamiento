# URL de la API (opcional — en dev usa proxy /api de Vite)
# En Vercel (produccion) el front usa /_/backend/api por defecto si no defines esta variable.
# VITE_API_URL=/_/backend/api

# Panel interno superadmin (/plataforma). En producción para una sola marca usar false.
# En desarrollo se habilita salvo que lo pongas explicitamente en false.
# VITE_PLATAFORMA_HABILITADA=false
